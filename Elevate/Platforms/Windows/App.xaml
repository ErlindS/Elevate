<maui:MauiWinUIApplication
    x:Class="Elevate.WinUI.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:maui="using:Microsoft.Maui"
    xmlns:local="using:Elevate.WinUI">

    <maui:MauiWinUIApplication.Resources>
        <ResourceDictionary>
            <!-- NavigationView Indicator: Grün statt Blau -->
            <SolidColorBrush x:Key="NavigationViewSelectionIndicatorForeground" Color="#3B7A57" />
            <SolidColorBrush x:Key="NavigationViewItemForegroundSelected" Color="#3B7A57" />
            <SolidColorBrush x:Key="NavigationViewItemForegroundSelectedPointerOver" Color="#3B7A57" />
            <SolidColorBrush x:Key="NavigationViewItemForegroundSelectedPressed" Color="#3B7A57" />
        </ResourceDictionary>
    </maui:MauiWinUIApplication.Resources>

</maui:MauiWinUIApplication>
