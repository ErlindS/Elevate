<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="Elevate.Views.WeeklyCalendarPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="Weekly Planner"
    Shell.NavBarIsVisible="False"
    BackgroundColor="{AppThemeBinding Light={StaticResource PageBackground}, Dark={StaticResource DarkPageBackground}}">

    <Grid RowDefinitions="Auto, *, Auto" Padding="0" RowSpacing="0">

        <!-- Navigation Header -->
        <Border Grid.Row="0" Background="{AppThemeBinding Light={StaticResource AppGradientBrush}, Dark={StaticResource DarkGradientBrush}}" StrokeThickness="0" StrokeShape="RoundRectangle 0,0,20,20" Padding="15,20,15,15">
        <Grid ColumnDefinitions="Auto, *, Auto" ColumnSpacing="10">
            <Button
                Grid.Column="0"
                BackgroundColor="{AppThemeBinding Light={StaticResource CardBackground}, Dark={StaticResource DarkCardBackground}}"
                Command="{Binding PreviousWeekCommand}"
                CornerRadius="8"
                FontAttributes="Bold"
                HeightRequest="36"
                Text="? Prev"
                TextColor="{AppThemeBinding Light={StaticResource PrimaryDark}, Dark={StaticResource DarkPrimaryDark}}"
                WidthRequest="75" />

            <Label
                Grid.Column="1"
                FontSize="16"
                FontAttributes="Bold"
                Text="{Binding WeekTitle}"
                TextColor="{AppThemeBinding Light={StaticResource CardBackground}, Dark={StaticResource DarkCardBackground}}"
                HorizontalOptions="Center"
                VerticalOptions="Center" />

            <Grid Grid.Column="2" ColumnDefinitions="Auto, Auto" ColumnSpacing="8">
                <Button
                    Grid.Column="0"
                    BackgroundColor="{AppThemeBinding Light={StaticResource CardBackground}, Dark={StaticResource DarkCardBackground}}"
                    Command="{Binding GoToTodayCommand}"
                    CornerRadius="8"
                    FontAttributes="Bold"
                    HeightRequest="36"
                    Text="Today"
                    TextColor="{AppThemeBinding Light={StaticResource Success}, Dark={StaticResource DarkSuccess}}"
                    WidthRequest="65" />

                <Button
                    Grid.Column="1"
                    BackgroundColor="{AppThemeBinding Light={StaticResource CardBackground}, Dark={StaticResource DarkCardBackground}}"
                    Command="{Binding NextWeekCommand}"
                    CornerRadius="8"
                    FontAttributes="Bold"
                    HeightRequest="36"
                    Text="Next ?"
                    TextColor="{AppThemeBinding Light={StaticResource PrimaryDark}, Dark={StaticResource DarkPrimaryDark}}"
                    WidthRequest="75" />
            </Grid>
        </Grid>
        </Border>

        <!-- Main Schedule Grid -->
        <ScrollView Grid.Row="1" Orientation="Both">
            <StackLayout Spacing="0" Padding="0">
                
                <!-- Header Row with Day Names -->
                <Grid ColumnDefinitions="50, 120, 120, 120, 120, 120, 120, 120, 200" ColumnSpacing="0" Padding="0" RowSpacing="0">
                    
                    <!-- Time Column Header -->
                    <BoxView Grid.Column="0" BackgroundColor="{AppThemeBinding Light={StaticResource CalendarGray}, Dark={StaticResource DarkCalendarGray}}" HeightRequest="50" />
                    
                    <!-- Day Headers -->
                    <Border Grid.Column="1" BackgroundColor="{AppThemeBinding Light={StaticResource CardBackground}, Dark={StaticResource DarkCardBackground}}" StrokeThickness="1" Stroke="{AppThemeBinding Light={StaticResource GridLine}, Dark={StaticResource DarkGridLine}}" Padding="8">
                        <StackLayout Spacing="2" HorizontalOptions="Center" VerticalOptions="Center">
                            <Label Text="{Binding WeekDays[0].DayName}" FontSize="12" FontAttributes="Bold" TextColor="{AppThemeBinding Light={StaticResource PrimaryDark}, Dark={StaticResource DarkPrimaryDark}}" HorizontalOptions="Center" />
                            <Label Text="{Binding WeekDays[0].DayDate}" FontSize="10" TextColor="{AppThemeBinding Light={StaticResource TextMuted}, Dark={StaticResource DarkTextMuted}}" HorizontalOptions="Center" />
                        </StackLayout>
                    </Border>
                    
                    <Border Grid.Column="2" BackgroundColor="{AppThemeBinding Light={StaticResource CardBackground}, Dark={StaticResource DarkCardBackground}}" StrokeThickness="1" Stroke="{AppThemeBinding Light={StaticResource GridLine}, Dark={StaticResource DarkGridLine}}" Padding="8">
                        <StackLayout Spacing="2" HorizontalOptions="Center" VerticalOptions="Center">
                            <Label Text="{Binding WeekDays[1].DayName}" FontSize="12" FontAttributes="Bold" TextColor="{AppThemeBinding Light={StaticResource PrimaryDark}, Dark={StaticResource DarkPrimaryDark}}" HorizontalOptions="Center" />
                            <Label Text="{Binding WeekDays[1].DayDate}" FontSize="10" TextColor="{AppThemeBinding Light={StaticResource TextMuted}, Dark={StaticResource DarkTextMuted}}" HorizontalOptions="Center" />
                        </StackLayout>
                    </Border>
                    
                    <Border Grid.Column="3" BackgroundColor="{AppThemeBinding Light={StaticResource CardBackground}, Dark={StaticResource DarkCardBackground}}" StrokeThickness="1" Stroke="{AppThemeBinding Light={StaticResource GridLine}, Dark={StaticResource DarkGridLine}}" Padding="8">
                        <StackLayout Spacing="2" HorizontalOptions="Center" VerticalOptions="Center">
                            <Label Text="{Binding WeekDays[2].DayName}" FontSize="12" FontAttributes="Bold" TextColor="{AppThemeBinding Light={StaticResource PrimaryDark}, Dark={StaticResource DarkPrimaryDark}}" HorizontalOptions="Center" />
                            <Label Text="{Binding WeekDays[2].DayDate}" FontSize="10" TextColor="{AppThemeBinding Light={StaticResource TextMuted}, Dark={StaticResource DarkTextMuted}}" HorizontalOptions="Center" />
                        </StackLayout>
                    </Border>
                    
                    <Border Grid.Column="4" BackgroundColor="{AppThemeBinding Light={StaticResource CardBackground}, Dark={StaticResource DarkCardBackground}}" StrokeThickness="1" Stroke="{AppThemeBinding Light={StaticResource GridLine}, Dark={StaticResource DarkGridLine}}" Padding="8">
                        <StackLayout Spacing="2" HorizontalOptions="Center" VerticalOptions="Center">
                            <Label Text="{Binding WeekDays[3].DayName}" FontSize="12" FontAttributes="Bold" TextColor="{AppThemeBinding Light={StaticResource PrimaryDark}, Dark={StaticResource DarkPrimaryDark}}" HorizontalOptions="Center" />
                            <Label Text="{Binding WeekDays[3].DayDate}" FontSize="10" TextColor="{AppThemeBinding Light={StaticResource TextMuted}, Dark={StaticResource DarkTextMuted}}" HorizontalOptions="Center" />
                        </StackLayout>
                    </Border>
                    
                    <Border Grid.Column="5" BackgroundColor="{AppThemeBinding Light={StaticResource CardBackground}, Dark={StaticResource DarkCardBackground}}" StrokeThickness="1" Stroke="{AppThemeBinding Light={StaticResource GridLine}, Dark={StaticResource DarkGridLine}}" Padding="8">
                        <StackLayout Spacing="2" HorizontalOptions="Center" VerticalOptions="Center">
                            <Label Text="{Binding WeekDays[4].DayName}" FontSize="12" FontAttributes="Bold" TextColor="{AppThemeBinding Light={StaticResource PrimaryDark}, Dark={StaticResource DarkPrimaryDark}}" HorizontalOptions="Center" />
                            <Label Text="{Binding WeekDays[4].DayDate}" FontSize="10" TextColor="{AppThemeBinding Light={StaticResource TextMuted}, Dark={StaticResource DarkTextMuted}}" HorizontalOptions="Center" />
                        </StackLayout>
                    </Border>
                    
                    <Border Grid.Column="6" BackgroundColor="{AppThemeBinding Light={StaticResource CardBackground}, Dark={StaticResource DarkCardBackground}}" StrokeThickness="1" Stroke="{AppThemeBinding Light={StaticResource GridLine}, Dark={StaticResource DarkGridLine}}" Padding="8">
                        <StackLayout Spacing="2" HorizontalOptions="Center" VerticalOptions="Center">
                            <Label Text="{Binding WeekDays[5].DayName}" FontSize="12" FontAttributes="Bold" TextColor="{AppThemeBinding Light={StaticResource PrimaryDark}, Dark={StaticResource DarkPrimaryDark}}" HorizontalOptions="Center" />
                            <Label Text="{Binding WeekDays[5].DayDate}" FontSize="10" TextColor="{AppThemeBinding Light={StaticResource TextMuted}, Dark={StaticResource DarkTextMuted}}" HorizontalOptions="Center" />
                        </StackLayout>
                    </Border>
                    
                    <Border Grid.Column="7" BackgroundColor="{AppThemeBinding Light={StaticResource CardBackground}, Dark={StaticResource DarkCardBackground}}" StrokeThickness="1" Stroke="{AppThemeBinding Light={StaticResource GridLine}, Dark={StaticResource DarkGridLine}}" Padding="8">
                        <StackLayout Spacing="2" HorizontalOptions="Center" VerticalOptions="Center">
                            <Label Text="{Binding WeekDays[6].DayName}" FontSize="12" FontAttributes="Bold" TextColor="{AppThemeBinding Light={StaticResource PrimaryDark}, Dark={StaticResource DarkPrimaryDark}}" HorizontalOptions="Center" />
                            <Label Text="{Binding WeekDays[6].DayDate}" FontSize="10" TextColor="{AppThemeBinding Light={StaticResource TextMuted}, Dark={StaticResource DarkTextMuted}}" HorizontalOptions="Center" />
                        </StackLayout>
                    </Border>
                    
                    <!-- Projects Header -->
                    <Border Grid.Column="8" BackgroundColor="{AppThemeBinding Light={StaticResource PrimaryLight}, Dark={StaticResource DarkPrimaryLight}}" StrokeThickness="1" Stroke="{AppThemeBinding Light={StaticResource GridLine}, Dark={StaticResource DarkGridLine}}" Padding="8">
                        <Label Text="Projekte" FontSize="12" FontAttributes="Bold" TextColor="{AppThemeBinding Light={StaticResource CardBackground}, Dark={StaticResource DarkCardBackground}}" HorizontalOptions="Center" VerticalOptions="Center" />
                    </Border>
                </Grid>

                <!-- Time Slots - CollectionView für dynamische Zeilen -->
                <CollectionView ItemsSource="{Binding TimeSlots}" SelectionMode="None">
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Grid ColumnDefinitions="50, 120, 120, 120, 120, 120, 120, 120, 200" ColumnSpacing="0" Padding="0" RowSpacing="0" HeightRequest="60">
                                
                                <!-- Hour Label -->
                                <Border Grid.Column="0" BackgroundColor="{AppThemeBinding Light={StaticResource CalendarGray}, Dark={StaticResource DarkCalendarGray}}" StrokeThickness="1" Stroke="{AppThemeBinding Light={StaticResource GridLine}, Dark={StaticResource DarkGridLine}}" Padding="4">
                                    <Label Text="{Binding DisplayTime}" FontSize="9" TextColor="{AppThemeBinding Light={StaticResource TextDark}, Dark={StaticResource DarkTextDark}}" HorizontalOptions="Center" VerticalOptions="Center" />
                                </Border>

                                <!-- Day Cells (7 Days) with Drop Support and Task Display -->
                                <Border Grid.Column="1" BackgroundColor="{AppThemeBinding Light={StaticResource CardBackground}, Dark={StaticResource DarkCardBackground}}" StrokeThickness="1" Stroke="{AppThemeBinding Light={StaticResource GridLine}, Dark={StaticResource DarkGridLine}}" Padding="4">
                                    <Border.GestureRecognizers>
                                        <DropGestureRecognizer AllowDrop="True" Drop="OnTimeSlotDrop" />
                                    </Border.GestureRecognizers>
                                    <StackLayout BindableLayout.ItemsSource="{Binding Day0Tasks}" Spacing="2">
                                        <BindableLayout.ItemTemplate>
                                            <DataTemplate>
                                                <Border BackgroundColor="{AppThemeBinding Light={StaticResource PrimaryDark}, Dark={StaticResource DarkPrimaryDark}}" Padding="4" StrokeShape="RoundRectangle 4" StrokeThickness="0">
                                                    <Label Text="{Binding Name}" FontSize="10" FontAttributes="Bold" TextColor="{AppThemeBinding Light={StaticResource CardBackground}, Dark={StaticResource DarkCardBackground}}" LineBreakMode="TailTruncation" HorizontalOptions="Center" />
                                                </Border>
                                            </DataTemplate>
                                        </BindableLayout.ItemTemplate>
                                    </StackLayout>
                                </Border>
                                <Border Grid.Column="2" BackgroundColor="{AppThemeBinding Light={StaticResource CardBackground}, Dark={StaticResource DarkCardBackground}}" StrokeThickness="1" Stroke="{AppThemeBinding Light={StaticResource GridLine}, Dark={StaticResource DarkGridLine}}" Padding="4">
                                    <Border.GestureRecognizers>
                                        <DropGestureRecognizer AllowDrop="True" Drop="OnTimeSlotDrop" />
                                    </Border.GestureRecognizers>
                                    <StackLayout BindableLayout.ItemsSource="{Binding Day1Tasks}" Spacing="2">
                                        <BindableLayout.ItemTemplate>
                                            <DataTemplate>
                                                <Border BackgroundColor="{AppThemeBinding Light={StaticResource PrimaryDark}, Dark={StaticResource DarkPrimaryDark}}" Padding="4" StrokeShape="RoundRectangle 4" StrokeThickness="0">
                                                    <Label Text="{Binding Name}" FontSize="10" FontAttributes="Bold" TextColor="{AppThemeBinding Light={StaticResource CardBackground}, Dark={StaticResource DarkCardBackground}}" LineBreakMode="TailTruncation" HorizontalOptions="Center" />
                                                </Border>
                                            </DataTemplate>
                                        </BindableLayout.ItemTemplate>
                                    </StackLayout>
                                </Border>
                                <Border Grid.Column="3" BackgroundColor="{AppThemeBinding Light={StaticResource CardBackground}, Dark={StaticResource DarkCardBackground}}" StrokeThickness="1" Stroke="{AppThemeBinding Light={StaticResource GridLine}, Dark={StaticResource DarkGridLine}}" Padding="4">
                                    <Border.GestureRecognizers>
                                        <DropGestureRecognizer AllowDrop="True" Drop="OnTimeSlotDrop" />
                                    </Border.GestureRecognizers>
                                    <StackLayout BindableLayout.ItemsSource="{Binding Day2Tasks}" Spacing="2">
                                        <BindableLayout.ItemTemplate>
                                            <DataTemplate>
                                                <Border BackgroundColor="{AppThemeBinding Light={StaticResource PrimaryDark}, Dark={StaticResource DarkPrimaryDark}}" Padding="4" StrokeShape="RoundRectangle 4" StrokeThickness="0">
                                                    <Label Text="{Binding Name}" FontSize="10" FontAttributes="Bold" TextColor="{AppThemeBinding Light={StaticResource CardBackground}, Dark={StaticResource DarkCardBackground}}" LineBreakMode="TailTruncation" HorizontalOptions="Center" />
                                                </Border>
                                            </DataTemplate>
                                        </BindableLayout.ItemTemplate>
                                    </StackLayout>
                                </Border>
                                <Border Grid.Column="4" BackgroundColor="{AppThemeBinding Light={StaticResource CardBackground}, Dark={StaticResource DarkCardBackground}}" StrokeThickness="1" Stroke="{AppThemeBinding Light={StaticResource GridLine}, Dark={StaticResource DarkGridLine}}" Padding="4">
                                    <Border.GestureRecognizers>
                                        <DropGestureRecognizer AllowDrop="True" Drop="OnTimeSlotDrop" />
                                    </Border.GestureRecognizers>
                                    <StackLayout BindableLayout.ItemsSource="{Binding Day3Tasks}" Spacing="2">
                                        <BindableLayout.ItemTemplate>
                                            <DataTemplate>
                                                <Border BackgroundColor="{AppThemeBinding Light={StaticResource PrimaryDark}, Dark={StaticResource DarkPrimaryDark}}" Padding="4" StrokeShape="RoundRectangle 4" StrokeThickness="0">
                                                    <Label Text="{Binding Name}" FontSize="10" FontAttributes="Bold" TextColor="{AppThemeBinding Light={StaticResource CardBackground}, Dark={StaticResource DarkCardBackground}}" LineBreakMode="TailTruncation" HorizontalOptions="Center" />
                                                </Border>
                                            </DataTemplate>
                                        </BindableLayout.ItemTemplate>
                                    </StackLayout>
                                </Border>
                                <Border Grid.Column="5" BackgroundColor="{AppThemeBinding Light={StaticResource CardBackground}, Dark={StaticResource DarkCardBackground}}" StrokeThickness="1" Stroke="{AppThemeBinding Light={StaticResource GridLine}, Dark={StaticResource DarkGridLine}}" Padding="4">
                                    <Border.GestureRecognizers>
                                        <DropGestureRecognizer AllowDrop="True" Drop="OnTimeSlotDrop" />
                                    </Border.GestureRecognizers>
                                    <StackLayout BindableLayout.ItemsSource="{Binding Day4Tasks}" Spacing="2">
                                        <BindableLayout.ItemTemplate>
                                            <DataTemplate>
                                                <Border BackgroundColor="{AppThemeBinding Light={StaticResource PrimaryDark}, Dark={StaticResource DarkPrimaryDark}}" Padding="4" StrokeShape="RoundRectangle 4" StrokeThickness="0">
                                                    <Label Text="{Binding Name}" FontSize="10" FontAttributes="Bold" TextColor="{AppThemeBinding Light={StaticResource CardBackground}, Dark={StaticResource DarkCardBackground}}" LineBreakMode="TailTruncation" HorizontalOptions="Center" />
                                                </Border>
                                            </DataTemplate>
                                        </BindableLayout.ItemTemplate>
                                    </StackLayout>
                                </Border>
                                <Border Grid.Column="6" BackgroundColor="{AppThemeBinding Light={StaticResource CardBackground}, Dark={StaticResource DarkCardBackground}}" StrokeThickness="1" Stroke="{AppThemeBinding Light={StaticResource GridLine}, Dark={StaticResource DarkGridLine}}" Padding="4">
                                    <Border.GestureRecognizers>
                                        <DropGestureRecognizer AllowDrop="True" Drop="OnTimeSlotDrop" />
                                    </Border.GestureRecognizers>
                                    <StackLayout BindableLayout.ItemsSource="{Binding Day5Tasks}" Spacing="2">
                                        <BindableLayout.ItemTemplate>
                                            <DataTemplate>
                                                <Border BackgroundColor="{AppThemeBinding Light={StaticResource PrimaryDark}, Dark={StaticResource DarkPrimaryDark}}" Padding="4" StrokeShape="RoundRectangle 4" StrokeThickness="0">
                                                    <Label Text="{Binding Name}" FontSize="10" FontAttributes="Bold" TextColor="{AppThemeBinding Light={StaticResource CardBackground}, Dark={StaticResource DarkCardBackground}}" LineBreakMode="TailTruncation" HorizontalOptions="Center" />
                                                </Border>
                                            </DataTemplate>
                                        </BindableLayout.ItemTemplate>
                                    </StackLayout>
                                </Border>
                                <Border Grid.Column="7" BackgroundColor="{AppThemeBinding Light={StaticResource CardBackground}, Dark={StaticResource DarkCardBackground}}" StrokeThickness="1" Stroke="{AppThemeBinding Light={StaticResource GridLine}, Dark={StaticResource DarkGridLine}}" Padding="4">
                                    <Border.GestureRecognizers>
                                        <DropGestureRecognizer AllowDrop="True" Drop="OnTimeSlotDrop" />
                                    </Border.GestureRecognizers>
                                    <StackLayout BindableLayout.ItemsSource="{Binding Day6Tasks}" Spacing="2">
                                        <BindableLayout.ItemTemplate>
                                            <DataTemplate>
                                                <Border BackgroundColor="{AppThemeBinding Light={StaticResource PrimaryDark}, Dark={StaticResource DarkPrimaryDark}}" Padding="4" StrokeShape="RoundRectangle 4" StrokeThickness="0">
                                                    <Label Text="{Binding Name}" FontSize="10" FontAttributes="Bold" TextColor="{AppThemeBinding Light={StaticResource CardBackground}, Dark={StaticResource DarkCardBackground}}" LineBreakMode="TailTruncation" HorizontalOptions="Center" />
                                                </Border>
                                            </DataTemplate>
                                        </BindableLayout.ItemTemplate>
                                    </StackLayout>
                                </Border>

                                <!-- Projects Column -->
                                <Border Grid.Column="8" BackgroundColor="{AppThemeBinding Light={StaticResource CalendarGray}, Dark={StaticResource DarkCalendarGray}}" StrokeThickness="1" Stroke="{AppThemeBinding Light={StaticResource GridLine}, Dark={StaticResource DarkGridLine}}" Padding="4" />
                            </Grid>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

            </StackLayout>
        </ScrollView>

        <!-- Unscheduled Subtasks (Draggable) -->
        <Border Grid.Row="2" BackgroundColor="{AppThemeBinding Light={StaticResource CardBackground}, Dark={StaticResource DarkCardBackground}}" StrokeThickness="1" Stroke="{AppThemeBinding Light={StaticResource Divider}, Dark={StaticResource DarkDivider}}" Padding="10">
            <StackLayout Spacing="8">
                <Label Text="Unscheduled Tasks" FontSize="14" FontAttributes="Bold" TextColor="{AppThemeBinding Light={StaticResource TextDark}, Dark={StaticResource DarkTextDark}}" />
                <CollectionView ItemsSource="{Binding SortedProjects}" HeightRequest="80">
                    <CollectionView.ItemsLayout>
                        <LinearItemsLayout Orientation="Horizontal" ItemSpacing="10" />
                    </CollectionView.ItemsLayout>
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Border StrokeShape="RoundRectangle 8" BackgroundColor="{AppThemeBinding Light={StaticResource PrimaryDark}, Dark={StaticResource DarkPrimaryDark}}" Padding="12,8" WidthRequest="150" StrokeThickness="0">
                                <Border.GestureRecognizers>
                                    <DragGestureRecognizer CanDrag="True" DragStartingCommand="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.StartDragCommand}" DragStartingCommandParameter="{Binding .}" />
                                </Border.GestureRecognizers>
                                <Label Text="{Binding Name}" FontSize="12" FontAttributes="Bold" TextColor="{AppThemeBinding Light={StaticResource CardBackground}, Dark={StaticResource DarkCardBackground}}" VerticalOptions="Center" HorizontalOptions="Center" LineBreakMode="TailTruncation" />
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </StackLayout>
        </Border>

    </Grid>
</ContentPage>