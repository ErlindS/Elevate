<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="Elevate.TodaysTaskPage"
    x:Name="Page1"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="Today's Tasks"
    Shell.NavBarIsVisible="False"
    BackgroundColor="{AppThemeBinding Light={StaticResource PageBackground}, Dark={StaticResource DarkPageBackground}}">

    <ScrollView
        Orientation="Vertical"
        VerticalScrollBarVisibility="Always"
        HorizontalOptions="Fill"
        VerticalOptions="Fill">
        <VerticalStackLayout
            Spacing="12"
            Padding="0,0,0,30"
            VerticalOptions="Start">

            <!-- Gradient Header -->
            <Border Background="{AppThemeBinding Light={StaticResource AppGradientBrush}, Dark={StaticResource DarkGradientBrush}}"
                    StrokeThickness="0"
                    StrokeShape="RoundRectangle 0,0,20,20"
                    Padding="20,30,20,20">
                <VerticalStackLayout Spacing="6">
                    <Label FontSize="28" FontAttributes="Bold" Text="Today's Tasks" TextColor="{AppThemeBinding Light={StaticResource CardBackground}, Dark={StaticResource DarkCardBackground}}" />
                    <HorizontalStackLayout Spacing="8">
                        <Label FontSize="16" Text="{Binding DayName}" TextColor="{AppThemeBinding Light={StaticResource CardBackground}, Dark={StaticResource DarkCardBackground}}" FontAttributes="Bold" Opacity="0.9" />
                        <Label FontSize="16" Text="{Binding TodayDate}" TextColor="{AppThemeBinding Light={StaticResource CardBackground}, Dark={StaticResource DarkCardBackground}}" Opacity="0.7" />
                    </HorizontalStackLayout>
                </VerticalStackLayout>
            </Border>

            <VerticalStackLayout Spacing="20" Padding="15,10,15,10">

                <Grid ColumnDefinitions="*, *, *" ColumnSpacing="10">
                    <Border Grid.Column="0" BackgroundColor="{AppThemeBinding Light={StaticResource CardBackground}, Dark={StaticResource DarkCardBackground}}" Padding="15" StrokeShape="RoundRectangle 12" StrokeThickness="1">
                        <VerticalStackLayout Spacing="8" HorizontalOptions="Center">
                            <Label FontSize="10" FontAttributes="Bold" Text="TOTAL" TextColor="{AppThemeBinding Light={StaticResource TextMuted}, Dark={StaticResource DarkTextMuted}}" HorizontalOptions="Center" />
                            <Label FontSize="24" FontAttributes="Bold" Text="{Binding TotalTaskCount}" TextColor="{AppThemeBinding Light={StaticResource PrimaryDark}, Dark={StaticResource DarkPrimaryDark}}" HorizontalOptions="Center" />
                        </VerticalStackLayout>
                    </Border>

                    <Border Grid.Column="1" BackgroundColor="{AppThemeBinding Light={StaticResource CardBackground}, Dark={StaticResource DarkCardBackground}}" Padding="15" StrokeShape="RoundRectangle 12" StrokeThickness="1">
                        <VerticalStackLayout Spacing="8" HorizontalOptions="Center">
                            <Label FontSize="10" FontAttributes="Bold" Text="COMPLETED" TextColor="{AppThemeBinding Light={StaticResource TextMuted}, Dark={StaticResource DarkTextMuted}}" HorizontalOptions="Center" />
                            <Label FontSize="24" FontAttributes="Bold" Text="{Binding CompletedTaskCount}" TextColor="{AppThemeBinding Light={StaticResource Success}, Dark={StaticResource DarkSuccess}}" HorizontalOptions="Center" />
                        </VerticalStackLayout>
                    </Border>

                    <Border Grid.Column="2" BackgroundColor="{AppThemeBinding Light={StaticResource CardBackground}, Dark={StaticResource DarkCardBackground}}" Padding="15" StrokeShape="RoundRectangle 12" StrokeThickness="1">
                        <VerticalStackLayout Spacing="8" HorizontalOptions="Center">
                            <Label FontSize="10" FontAttributes="Bold" Text="COMPLETION" TextColor="{AppThemeBinding Light={StaticResource TextMuted}, Dark={StaticResource DarkTextMuted}}" HorizontalOptions="Center" />
                            <Label FontSize="24" FontAttributes="Bold" Text="{Binding CompletionPercentage, StringFormat='{0:F0}%'}" TextColor="{AppThemeBinding Light={StaticResource Warning}, Dark={StaticResource DarkWarning}}" HorizontalOptions="Center" />
                        </VerticalStackLayout>
                    </Border>
                </Grid>

                <Border BackgroundColor="{AppThemeBinding Light={StaticResource CardBackground}, Dark={StaticResource DarkCardBackground}}" Padding="15" StrokeShape="RoundRectangle 12" StrokeThickness="1">
                    <VerticalStackLayout Spacing="10">
                        <Label FontSize="12" FontAttributes="Bold" Text="Progress" TextColor="{AppThemeBinding Light={StaticResource TextDark}, Dark={StaticResource DarkTextDark}}" />
                        <ProgressBar Progress="{Binding CompletionPercentage}" ProgressColor="{AppThemeBinding Light={StaticResource Success}, Dark={StaticResource DarkSuccess}}" />
                    </VerticalStackLayout>
                </Border>

                <Button BackgroundColor="{AppThemeBinding Light={StaticResource PrimaryDark}, Dark={StaticResource DarkPrimaryDark}}" Command="{Binding RefreshTasksCommand}" CornerRadius="12" FontAttributes="Bold" HeightRequest="40" Text="Refresh Tasks" TextColor="{AppThemeBinding Light={StaticResource CardBackground}, Dark={StaticResource DarkCardBackground}}" />

            </VerticalStackLayout>


             <!-- Task List-->
            <StackLayout
                BindableLayout.ItemsSource="{Binding TodaysTasks}"
                Spacing="12"
                Padding="15,0">

                <BindableLayout.EmptyView>
                    <Label
                        Margin="0,20"
                        FontSize="18"
                        HorizontalOptions="Center"
                        Text="No tasks for today."
                        TextColor="{AppThemeBinding Light={StaticResource TextPlaceholder}, Dark={StaticResource DarkTextPlaceholder}}" />
                </BindableLayout.EmptyView>

                <BindableLayout.ItemTemplate>
                    <DataTemplate>
                        <Border Padding="15" BackgroundColor="{AppThemeBinding Light={StaticResource CardBackground}, Dark={StaticResource DarkCardBackground}}" StrokeShape="RoundRectangle 15" StrokeThickness="0">

                            <Grid RowDefinitions="Auto, Auto, Auto, Auto" Padding="0">

                                <Grid Grid.Row="0" ColumnDefinitions="Auto, *, Auto" ColumnSpacing="12">
                                    <CheckBox Grid.Column="0" IsChecked="{Binding IsDone}" Color="{AppThemeBinding Light={StaticResource PrimaryDark}, Dark={StaticResource DarkPrimaryDark}}" VerticalOptions="Center" />
                                    <Button
                                        BackgroundColor="{AppThemeBinding Light={StaticResource PrimaryDark}, Dark={StaticResource DarkPrimaryDark}}"
                                        Command="{Binding Source={x:Reference Page1}, Path=BindingContext.BaseCommand}"
                                        CommandParameter="{Binding Id}"
                                        CornerRadius="20"
                                        FontAttributes="Bold"
                                        HeightRequest="40"
                                        Text="Base"
                                        TextColor="{AppThemeBinding Light={StaticResource CardBackground}, Dark={StaticResource DarkCardBackground}}" />
                                    <VerticalStackLayout Grid.Column="1" Spacing="4">
                                        <Label FontSize="14" FontAttributes="Bold" LineBreakMode="TailTruncation" Text="{Binding Name}" TextColor="{AppThemeBinding Light={StaticResource TextDark}, Dark={StaticResource DarkTextDark}}" />
                                        <Label FontSize="11" Text="{Binding Category}" TextColor="{AppThemeBinding Light={StaticResource TextMuted}, Dark={StaticResource DarkTextMuted}}" />
                                    </VerticalStackLayout>
                                    <Label Grid.Column="2" FontSize="12" FontAttributes="Bold" Text="{Binding Priority, StringFormat='P{0}'}" TextColor="{AppThemeBinding Light={StaticResource PrimaryDark}, Dark={StaticResource DarkPrimaryDark}}" VerticalOptions="Center" />
                                </Grid>

                                <BoxView Grid.Row="1" Margin="0,12,0,12" BackgroundColor="{AppThemeBinding Light={StaticResource Divider}, Dark={StaticResource DarkDivider}}" HeightRequest="1" />

                                <VerticalStackLayout Grid.Row="2" Spacing="3">
                                    <Label FontSize="10" FontAttributes="Bold" Text="DESCRIPTION" TextColor="{AppThemeBinding Light={StaticResource TextMuted}, Dark={StaticResource DarkTextMuted}}" />
                                    <Label FontSize="12" LineBreakMode="WordWrap" Text="{Binding Description}" TextColor="{AppThemeBinding Light={StaticResource TextDark}, Dark={StaticResource DarkTextDark}}" />
                                </VerticalStackLayout>

                                <VerticalStackLayout Grid.Row="3" Spacing="5" Margin="0,15,0,0">
                                    <Label FontSize="10" FontAttributes="Bold" Text="FUNCTIONS / CRITERIA" TextColor="{AppThemeBinding Light={StaticResource TextMuted}, Dark={StaticResource DarkTextMuted}}" />

                                    <!-- Here are all Fit criteria -->
                                    <StackLayout BindableLayout.ItemsSource="{Binding Fitcriteria}" Spacing="2">
                                        <BindableLayout.ItemTemplate>
                                            <DataTemplate>
                                                <HorizontalStackLayout Spacing="8">
                                                    <CheckBox Color="{AppThemeBinding Light={StaticResource PrimaryDark}, Dark={StaticResource DarkPrimaryDark}}" VerticalOptions="Center" Scale="0.8" />
                                                    <Label Text="{Binding .}" FontSize="12" TextColor="{AppThemeBinding Light={StaticResource TextDark}, Dark={StaticResource DarkTextDark}}" VerticalOptions="Center" />
                                                </HorizontalStackLayout>
                                            </DataTemplate>
                                        </BindableLayout.ItemTemplate>
                                    </StackLayout>

                                    <!-- Here are all Subtasks  -->
                                    <StackLayout BindableLayout.ItemsSource="{Binding SubTasks}" Spacing="2">
                                        <BindableLayout.ItemTemplate>
                                            <DataTemplate>
                                                <HorizontalStackLayout Spacing="8">
                                                    <CheckBox Color="{AppThemeBinding Light={StaticResource PrimaryDark}, Dark={StaticResource DarkPrimaryDark}}" VerticalOptions="Center" Scale="0.8" />
                                                    <Label Text="{Binding .}" FontSize="12" TextColor="{AppThemeBinding Light={StaticResource TextDark}, Dark={StaticResource DarkTextDark}}" VerticalOptions="Center" />
                                                </HorizontalStackLayout>
                                            </DataTemplate>
                                        </BindableLayout.ItemTemplate>
                                    </StackLayout>
                                    
                                </VerticalStackLayout>

                            </Grid>

                        </Border>
                    </DataTemplate>
                </BindableLayout.ItemTemplate>
            </StackLayout>

            <BoxView HeightRequest="50" Color="Transparent" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>