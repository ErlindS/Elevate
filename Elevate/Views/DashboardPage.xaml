<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="Elevate.DashboardPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="Dashboard"
    Shell.NavBarIsVisible="False"
    BackgroundColor="{AppThemeBinding Light={StaticResource PageBackground}, Dark={StaticResource DarkPageBackground}}">

    <Grid RowDefinitions="Auto, Auto, Auto, *" Padding="0">

        <!-- Gradient Header -->
        <Border Grid.Row="0"
                Background="{AppThemeBinding Light={StaticResource AppGradientBrush}, Dark={StaticResource DarkGradientBrush}}"
                StrokeThickness="0"
                StrokeShape="RoundRectangle 0,0,20,20"
                Padding="20,30,20,20">
            <Label
                FontSize="28"
                FontAttributes="Bold"
                Text="Task Dashboard"
                TextColor="{AppThemeBinding Light={StaticResource CardBackground}, Dark={StaticResource DarkCardBackground}}" />
        </Border>

        <!-- Stats -->
        <StackLayout
            Grid.Row="1"
            Margin="15,15,15,0"
            Spacing="15">

            <!-- Statistics Grid -->
            <Grid
                ColumnDefinitions="*, *, *"
                ColumnSpacing="10"
                RowSpacing="10">

                <Border
                    Grid.Column="0"
                    BackgroundColor="{AppThemeBinding Light={StaticResource CardBackground}, Dark={StaticResource DarkCardBackground}}"
                    Padding="15"
                    StrokeShape="RoundRectangle 12"
                    StrokeThickness="1">
                    <Border.Shadow>
                        <Shadow
                            Brush="Black"
                            Opacity="0.05"
                            Radius="5"
                            Offset="0,2" />
                    </Border.Shadow>
                    <StackLayout Spacing="8" HorizontalOptions="Center">
                        <Label
                            FontSize="10"
                            FontAttributes="Bold"
                            Text="TOTAL"
                            TextColor="{AppThemeBinding Light={StaticResource TextMuted}, Dark={StaticResource DarkTextMuted}}"
                            HorizontalOptions="Center" />
                        <Label
                            FontSize="24"
                            FontAttributes="Bold"
                            Text="{Binding TotalTaskCount}"
                            TextColor="{AppThemeBinding Light={StaticResource PrimaryDark}, Dark={StaticResource DarkPrimaryDark}}"
                            HorizontalOptions="Center" />
                    </StackLayout>
                </Border>

                <Border
                    Grid.Column="1"
                    BackgroundColor="{AppThemeBinding Light={StaticResource CardBackground}, Dark={StaticResource DarkCardBackground}}"
                    Padding="15"
                    StrokeShape="RoundRectangle 12"
                    StrokeThickness="1">
                    <Border.Shadow>
                        <Shadow
                            Brush="Black"
                            Opacity="0.05"
                            Radius="5"
                            Offset="0,2" />
                    </Border.Shadow>
                    <StackLayout Spacing="8" HorizontalOptions="Center">
                        <Label
                            FontSize="10"
                            FontAttributes="Bold"
                            Text="COMPLETED"
                            TextColor="{AppThemeBinding Light={StaticResource TextMuted}, Dark={StaticResource DarkTextMuted}}"
                            HorizontalOptions="Center" />
                        <Label
                            FontSize="24"
                            FontAttributes="Bold"
                            Text="{Binding CompletedTaskCount}"
                            TextColor="{AppThemeBinding Light={StaticResource Success}, Dark={StaticResource DarkSuccess}}"
                            HorizontalOptions="Center" />
                    </StackLayout>
                </Border>

                <Border
                    Grid.Column="2"
                    BackgroundColor="{AppThemeBinding Light={StaticResource CardBackground}, Dark={StaticResource DarkCardBackground}}"
                    Padding="15"
                    StrokeShape="RoundRectangle 12"
                    StrokeThickness="1">
                    <Border.Shadow>
                        <Shadow
                            Brush="Black"
                            Opacity="0.05"
                            Radius="5"
                            Offset="0,2" />
                    </Border.Shadow>
                    <StackLayout Spacing="8" HorizontalOptions="Center">
                        <Label
                            FontSize="10"
                            FontAttributes="Bold"
                            Text="PENDING"
                            TextColor="{AppThemeBinding Light={StaticResource TextMuted}, Dark={StaticResource DarkTextMuted}}"
                            HorizontalOptions="Center" />
                        <Label
                            FontSize="24"
                            FontAttributes="Bold"
                            Text="{Binding PendingTaskCount}"
                            TextColor="{AppThemeBinding Light={StaticResource Warning}, Dark={StaticResource DarkWarning}}"
                            HorizontalOptions="Center" />
                    </StackLayout>
                </Border>
            </Grid>

            <!-- Progress Bar -->
            <Border
                BackgroundColor="{AppThemeBinding Light={StaticResource CardBackground}, Dark={StaticResource DarkCardBackground}}"
                Padding="15"
                StrokeShape="RoundRectangle 12"
                StrokeThickness="1">
                <Border.Shadow>
                    <Shadow
                        Brush="Black"
                        Opacity="0.05"
                        Radius="5"
                        Offset="0,2" />
                </Border.Shadow>
                <StackLayout Spacing="10">
                    <Grid ColumnDefinitions="*, Auto">
                        <Label
                            Grid.Column="0"
                            FontSize="12"
                            FontAttributes="Bold"
                            Text="Completion Rate"
                            TextColor="{AppThemeBinding Light={StaticResource TextDark}, Dark={StaticResource DarkTextDark}}" />
                        <Label
                            Grid.Column="1"
                            FontSize="12"
                            FontAttributes="Bold"
                            Text="{Binding CompletionPercentage, StringFormat='{0:F1}%'}"
                            TextColor="{AppThemeBinding Light={StaticResource PrimaryDark}, Dark={StaticResource DarkPrimaryDark}}" />
                    </Grid>
                    <ProgressBar
                        Progress="{Binding CompletionPercentage, Converter={StaticResource PercentageConverter}}"
                        ProgressColor="{AppThemeBinding Light={StaticResource Success}, Dark={StaticResource DarkSuccess}}" />
                </StackLayout>
            </Border>
        </StackLayout>

        <!-- Controls -->
        <StackLayout
            Grid.Row="2"
            Orientation="Horizontal"
            Spacing="10"
            Margin="15,15,15,15">

            <Button
                BackgroundColor="{AppThemeBinding Light={StaticResource PrimaryDark}, Dark={StaticResource DarkPrimaryDark}}"
                Command="{Binding RefreshDataCommand}"
                CornerRadius="12"
                FontAttributes="Bold"
                HeightRequest="40"
                Text="Refresh"
                TextColor="{AppThemeBinding Light={StaticResource CardBackground}, Dark={StaticResource DarkCardBackground}}"
                WidthRequest="100" />

            <Button
                BackgroundColor="{AppThemeBinding Light={StaticResource PrimaryDark}, Dark={StaticResource DarkPrimaryDark}}"
                Command="{Binding CopyJsonToClipboardCommand}"
                CornerRadius="12"
                FontAttributes="Bold"
                HeightRequest="40"
                Text="Copy JSON"
                TextColor="{AppThemeBinding Light={StaticResource CardBackground}, Dark={StaticResource DarkCardBackground}}" />
        </StackLayout>

        <!-- JSON Viewer -->
        <Border
            Grid.Row="3"
            Margin="15,0,15,15"
            BackgroundColor="{AppThemeBinding Light={StaticResource CardBackground}, Dark={StaticResource DarkCardBackground}}"
            Padding="15"
            StrokeShape="RoundRectangle 12"
            StrokeThickness="1">
            <Border.Shadow>
                <Shadow
                    Brush="Black"
                    Opacity="0.05"
                    Radius="5"
                    Offset="0,2" />
            </Border.Shadow>

            <StackLayout Spacing="10">
                <Label
                    FontSize="14"
                    FontAttributes="Bold"
                    Text="JSON Output"
                    TextColor="{AppThemeBinding Light={StaticResource TextDark}, Dark={StaticResource DarkTextDark}}" />

                <ScrollView>
                    <Label
                        FontFamily="Courier"
                        FontSize="11"
                        LineBreakMode="WordWrap"
                        Text="{Binding JsonOutput}"
                        TextColor="{AppThemeBinding Light={StaticResource TextDark}, Dark={StaticResource DarkTextDark}}" />
                </ScrollView>
            </StackLayout>
        </Border>

    </Grid>
</ContentPage>