<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="Elevate.AddTaskPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Name="Page"
    Shell.NavBarIsVisible="False"
    BackgroundColor="{AppThemeBinding Light={StaticResource PageBackground}, Dark={StaticResource DarkPageBackground}}">

    <!-- Use Grid to constrain ScrollView to page bounds -->
    <Grid RowDefinitions="Auto, *">
        <!-- Gradient Header -->
        <Border Grid.Row="0"
                Background="{AppThemeBinding Light={StaticResource AppGradientBrush}, Dark={StaticResource DarkGradientBrush}}"
                StrokeThickness="0"
                StrokeShape="RoundRectangle 0,0,20,20"
                Padding="20,30,20,20">
            <Label FontSize="28" FontAttributes="Bold" Text="New Task" TextColor="{AppThemeBinding Light={StaticResource CardBackground}, Dark={StaticResource DarkCardBackground}}" />
        </Border>

        <ScrollView
            Grid.Row="1"
            Orientation="Vertical"
            VerticalScrollBarVisibility="Always">
            <VerticalStackLayout
                Spacing="12"
                Padding="0,0,0,30">

                <!-- Header / New Task Form -->
                <Border
                    Margin="20,10,20,10"
                    BackgroundColor="{AppThemeBinding Light={StaticResource CardBackground}, Dark={StaticResource DarkCardBackground}}"
                    StrokeShape="RoundRectangle 15"
                    StrokeThickness="1"
                    Padding="15">

                    <Border.Shadow>
                        <Shadow
                            Brush="Black"
                            Opacity="0.05"
                            Radius="10"
                            Offset="0,4" />
                    </Border.Shadow>

                    <StackLayout Spacing="15">
                        <Label
                            FontSize="18"
                            FontAttributes="Bold"
                            Text="New Task"
                            TextColor="{AppThemeBinding Light={StaticResource TextDark}, Dark={StaticResource DarkTextDark}}" />

                        <Entry
                            FontSize="14"
                            Placeholder="Task Name *"
                            PlaceholderColor="{AppThemeBinding Light={StaticResource TextPlaceholder}, Dark={StaticResource DarkTextPlaceholder}}"
                            IsTextPredictionEnabled="True"
                            Text="{Binding NewTodoText}"
                            TextColor="{AppThemeBinding Light={StaticResource TextDark}, Dark={StaticResource DarkTextDark}}" />

                        <Editor
                            FontSize="14"
                            Placeholder="Description"
                            PlaceholderColor="{AppThemeBinding Light={StaticResource TextPlaceholder}, Dark={StaticResource DarkTextPlaceholder}}"
                            Text="{Binding NewTaskDescription}"
                            TextColor="{AppThemeBinding Light={StaticResource TextDark}, Dark={StaticResource DarkTextDark}}"
                            AutoSize="TextChanges" />

                        <StackLayout BindableLayout.ItemsSource="{Binding FitCriteria}" Spacing="10">
                            <BindableLayout.ItemTemplate>
                                <DataTemplate>
                                    <Entry
                                        FontSize="14"
                                        Placeholder="Benötigte Funktion eingeben..."
                                        PlaceholderColor="{AppThemeBinding Light={StaticResource TextPlaceholder}, Dark={StaticResource DarkTextPlaceholder}}"
                                        Text="{Binding Text}" 
                                        TextColor="{AppThemeBinding Light={StaticResource TextDark}, Dark={StaticResource DarkTextDark}}"
                                        ReturnCommand="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.CheckAndAddNewCriterionCommand}"
                                        ReturnCommandParameter="{Binding .}"/>
                                </DataTemplate>
                            </BindableLayout.ItemTemplate>
                        </StackLayout>

                        <Entry
                            FontSize="14"
                            Placeholder="Category"
                            PlaceholderColor="{AppThemeBinding Light={StaticResource TextPlaceholder}, Dark={StaticResource DarkTextPlaceholder}}"
                            Text="{Binding NewTaskCategory}"
                            TextColor="{AppThemeBinding Light={StaticResource TextDark}, Dark={StaticResource DarkTextDark}}" />

                        <Grid ColumnDefinitions="*, Auto" ColumnSpacing="10">
                            <Entry
                                Grid.Column="0"
                                FontSize="14"
                                Placeholder="Priority (1-5)"
                                PlaceholderColor="{AppThemeBinding Light={StaticResource TextPlaceholder}, Dark={StaticResource DarkTextPlaceholder}}"
                                Text="{Binding NewTaskPriority}"
                                TextColor="{AppThemeBinding Light={StaticResource TextDark}, Dark={StaticResource DarkTextDark}}"
                                Keyboard="Numeric" />

                            <Picker
                                Grid.Column="1"
                                FontSize="14"
                                ItemsSource="{Binding AvailableDays}"
                                SelectedItem="{Binding SelectedDay}"
                                TextColor="{AppThemeBinding Light={StaticResource TextDark}, Dark={StaticResource DarkTextDark}}"
                                Title="Select Day" />
                        </Grid>

                        <Grid ColumnDefinitions="*, Auto">
                            <Label
                                Grid.Column="0"
                                FontSize="12"
                                Text="{Binding SelectedDay, StringFormat='Scheduled for: {0}'}"
                                TextColor="{AppThemeBinding Light={StaticResource TextMuted}, Dark={StaticResource DarkTextMuted}}"
                                VerticalOptions="Center" />

                            <Button
                                Grid.Column="1"
                                Margin="10,0,0,0"
                                BackgroundColor="{AppThemeBinding Light={StaticResource PrimaryDark}, Dark={StaticResource DarkPrimaryDark}}"
                                Command="{Binding AddItemCommand}"
                                CornerRadius="12"
                                FontAttributes="Bold"
                                HeightRequest="40"
                                Text="Add Task"
                                TextColor="{AppThemeBinding Light={StaticResource CardBackground}, Dark={StaticResource DarkCardBackground}}"
                                WidthRequest="100" />
                        </Grid>
                    </StackLayout>
                </Border>

                <!-- Tasks List using BindableLayout -->
                <StackLayout
                    BindableLayout.ItemsSource="{Binding Tasks.SubTasks}"
                    Spacing="12"
                    Padding="20,0">

                    <BindableLayout.EmptyView>
                        <Label
                            Margin="0,20"
                            FontSize="18"
                            HorizontalOptions="Center"
                            Text="No tasks yet."
                            TextColor="{AppThemeBinding Light={StaticResource TextPlaceholder}, Dark={StaticResource DarkTextPlaceholder}}" />
                    </BindableLayout.EmptyView>

                    <BindableLayout.ItemTemplate>
                        <DataTemplate>
                            <Border
                                Padding="15"
                                BackgroundColor="{AppThemeBinding Light={StaticResource CardBackground}, Dark={StaticResource DarkCardBackground}}"
                                StrokeShape="RoundRectangle 15"
                                StrokeThickness="0">

                                <Border.Shadow>
                                    <Shadow
                                        Brush="Black"
                                        Opacity="0.05"
                                        Radius="5"
                                        Offset="0,2" />
                                </Border.Shadow>

                                <Grid RowDefinitions="Auto, Auto, Auto" Padding="0">
                                    <Grid Grid.Row="0" ColumnDefinitions="Auto, *, Auto">
                                        <CheckBox
                                            Grid.Column="0"
                                            IsChecked="{Binding IsDone}"
                                            Color="{AppThemeBinding Light={StaticResource PrimaryDark}, Dark={StaticResource DarkPrimaryDark}}"
                                            VerticalOptions="Center" />

                                        <StackLayout Grid.Column="1" Spacing="5" Margin="10,0">
                                            <Label
                                                FontSize="16"
                                                FontAttributes="Bold"
                                                LineBreakMode="TailTruncation"
                                                Text="{Binding Name}"
                                                TextColor="{AppThemeBinding Light={StaticResource TextDark}, Dark={StaticResource DarkTextDark}}" />

                                            <Label 
                                                FontSize="16"
                                                FontAttributes="Bold"
                                                Text="{Binding Description}"
                                                TextColor="{StaticResource Gray300}" />
                                            <Label
                                                FontSize="12"
                                                Text="{Binding Category}"
                                                TextColor="{AppThemeBinding Light={StaticResource TextMuted}, Dark={StaticResource DarkTextMuted}}" />
                                        </StackLayout>

                                        <Button
                                            Grid.Column="2"
                                            Margin="10"
                                            BackgroundColor="{AppThemeBinding Light={StaticResource PrimaryDark}, Dark={StaticResource DarkPrimaryDark}}"
                                            Command="{Binding Source={x:Reference Page}, Path=BindingContext.DeleteItemCommand}"
                                            CommandParameter="{Binding Id}"
                                            CornerRadius="12"
                                            FontAttributes="Bold"
                                            HeightRequest="36"
                                            Text="Delete"
                                            TextColor="{AppThemeBinding Light={StaticResource CardBackground}, Dark={StaticResource DarkCardBackground}}"
                                            WidthRequest="75" />
                                        
                                    </Grid>

                                    <BoxView
                                        Grid.Row="1"
                                        Margin="0,8,0,8"
                                        BackgroundColor="{AppThemeBinding Light={StaticResource Divider}, Dark={StaticResource DarkDivider}}"
                                        HeightRequest="1" />

                                    <Grid Grid.Row="2" ColumnDefinitions="*, *" RowSpacing="5" ColumnSpacing="10">
                                        <StackLayout Grid.Column="0" Spacing="3">
                                            <Label
                                                FontSize="10"
                                                FontAttributes="Bold"
                                                Text="PRIORITY"
                                                TextColor="{AppThemeBinding Light={StaticResource TextMuted}, Dark={StaticResource DarkTextMuted}}" />
                                            <Label
                                                FontSize="14"
                                                Text="{Binding Priority}"
                                                TextColor="{AppThemeBinding Light={StaticResource TextDark}, Dark={StaticResource DarkTextDark}}" />
                                        </StackLayout>

                                        <StackLayout Grid.Column="1" Spacing="3">
                                            <Label
                                                FontSize="10"
                                                FontAttributes="Bold"
                                                Text="SCHEDULED"
                                                TextColor="{AppThemeBinding Light={StaticResource TextMuted}, Dark={StaticResource DarkTextMuted}}" />
                                            <Label
                                                FontSize="12"
                                                LineBreakMode="TailTruncation"
                                                Text="{Binding ScheduledDate, StringFormat='{0:dd.MM.yyyy}'}"
                                                TextColor="{AppThemeBinding Light={StaticResource TextDark}, Dark={StaticResource DarkTextDark}}" />
                                        </StackLayout>
                                    </Grid>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </BindableLayout.ItemTemplate>
                </StackLayout>


            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>