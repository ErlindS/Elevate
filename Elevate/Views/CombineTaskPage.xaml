<ContentPage
    x:Class="Elevate.CombineTaskPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Name="Page2"
    BackgroundColor="{AppThemeBinding Light={StaticResource PageBackground}, Dark={StaticResource DarkPageBackground}}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="80" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="2*" />
        </Grid.ColumnDefinitions>

        <Label
            Grid.Row="0"
            Grid.Column="0"
            Margin="10"
            LineBreakMode="WordWrap"
            Text="{Binding CurrentProjectLevelTask.Name}" 
            TextColor="{AppThemeBinding Light={StaticResource TextDark}, Dark={StaticResource DarkTextDark}}"
            VerticalOptions="Center" />

        <Button
            Grid.Row="0"
            Grid.Column="1"
            Margin="10"
            BackgroundColor="{AppThemeBinding Light={StaticResource PrimaryDark}, Dark={StaticResource DarkPrimaryDark}}"
            Command="{Binding Source={x:Reference Page2}, Path=BindingContext.OutCommand}"
            CommandParameter="{Binding Id}"
            CornerRadius="20"
            FontAttributes="Bold"
            HeightRequest="40"
            Text="Out"
            TextColor="{AppThemeBinding Light={StaticResource CardBackground}, Dark={StaticResource DarkCardBackground}}" />

        <CollectionView
            Grid.Row="1"
            Grid.ColumnSpan="2"
            Margin="0,10,0,0"
            ItemsSource="{Binding CurrentProjectLevelTask.SubTasks}">

            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Grid Padding="10">
                        <Border
                            Padding="15"
                            BackgroundColor="{AppThemeBinding Light={StaticResource CardBackground}, Dark={StaticResource DarkCardBackground}}"
                            Stroke="{AppThemeBinding Light={StaticResource PrimaryLight}, Dark={StaticResource DarkPrimaryLight}}"
                            StrokeShape="RoundRectangle 10"
                            StrokeThickness="1">
                            <Grid ColumnDefinitions="*, *, *">

                                <Label
                                    Grid.Column="0"
                                    LineBreakMode="WordWrap"
                                    Text="{Binding Name}"
                                    TextColor="{AppThemeBinding Light={StaticResource TextDark}, Dark={StaticResource DarkTextDark}}"
                                    VerticalOptions="Center" />

                                <Button
                                    Grid.Column="1"
                                    Margin="10"
                                    BackgroundColor="{AppThemeBinding Light={StaticResource PrimaryDark}, Dark={StaticResource DarkPrimaryDark}}"
                                    Command="{Binding Source={x:Reference Page2}, Path=BindingContext.BaseCommand}"
                                    CommandParameter="{Binding Id}"
                                    CornerRadius="20"
                                    FontAttributes="Bold"
                                    HeightRequest="40"
                                    Text="Base"
                                    TextColor="{AppThemeBinding Light={StaticResource CardBackground}, Dark={StaticResource DarkCardBackground}}" />

                                <Button
                                    Grid.Column="2"
                                    Margin="10"
                                    BackgroundColor="{AppThemeBinding Light={StaticResource PrimaryDark}, Dark={StaticResource DarkPrimaryDark}}"
                                    Command="{Binding Source={x:Reference Page2}, Path=BindingContext.RemoveTaskCommand}"
                                    CommandParameter="{Binding Id}"
                                    CornerRadius="20"
                                    FontAttributes="Bold"
                                    HeightRequest="40"
                                    Text="Remove"
                                    TextColor="{AppThemeBinding Light={StaticResource CardBackground}, Dark={StaticResource DarkCardBackground}}" />
                            </Grid>
                        </Border>
                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <Label
            Grid.Row="0"
            Grid.Column="2" 
            Margin="10"
            LineBreakMode="WordWrap"
            Text="Unsorted Tasks"
            TextColor="{AppThemeBinding Light={StaticResource TextDark}, Dark={StaticResource DarkTextDark}}"
            VerticalOptions="Center" />

        <CollectionView
            Grid.Row="1"
            Grid.Column="2"
            Margin="0,10,0,0"
            ItemsSource="{Binding UnsortedTasks.SubTasks}">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Grid Padding="10">
                        <Border
                            Padding="15"
                            BackgroundColor="{AppThemeBinding Light={StaticResource CardBackground}, Dark={StaticResource DarkCardBackground}}"
                            Stroke="{AppThemeBinding Light={StaticResource PrimaryLight}, Dark={StaticResource DarkPrimaryLight}}"
                            StrokeShape="RoundRectangle 10"
                            StrokeThickness="1">
                            <Grid ColumnDefinitions="Auto, *">

                                <Button
                                    Grid.Column="0"
                                    Margin="10"
                                    BackgroundColor="{AppThemeBinding Light={StaticResource PrimaryDark}, Dark={StaticResource DarkPrimaryDark}}"
                                    Command="{Binding Source={x:Reference Page2}, Path=BindingContext.MoveTaskCommand}"
                                    CommandParameter="{Binding Id}"
                                    CornerRadius="20"
                                    FontAttributes="Bold"
                                    HeightRequest="40"
                                    Text="Add"
                                    TextColor="{AppThemeBinding Light={StaticResource CardBackground}, Dark={StaticResource DarkCardBackground}}"
                                    WidthRequest="80" />

                                <Label
                                    Grid.Column="1"
                                    LineBreakMode="WordWrap"
                                    Text="{Binding Name}"
                                    TextColor="{AppThemeBinding Light={StaticResource TextDark}, Dark={StaticResource DarkTextDark}}"
                                    VerticalOptions="Center" />
                            </Grid>
                        </Border>
                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

    </Grid>
</ContentPage>