<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="Elevate.ExportPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Name="Page4"
    Shell.NavBarIsVisible="False"
    BackgroundColor="{StaticResource PageBackground}">

    <ScrollView>
        <VerticalStackLayout Spacing="15">
            
            <!-- Gradient Header -->
            <Border Background="{StaticResource AppGradientBrush}"
                    StrokeThickness="0"
                    StrokeShape="RoundRectangle 0,0,20,20"
                    Padding="20,30,20,20">
                <Label 
                    Text="Export &amp; Import" 
                    FontSize="28" 
                    FontAttributes="Bold"
                    TextColor="{StaticResource CardBackground}"
                    HorizontalOptions="Center"/>
            </Border>

            <!-- Status Message -->
            <Border 
                StrokeShape="RoundRectangle 10"
                Padding="15"
                Margin="20,0"
                BackgroundColor="{StaticResource StatusBackground}"
                Stroke="{StaticResource PrimaryLight}">
                <Label 
                    Text="{Binding StatusMessage}"
                    FontSize="14"
                    HorizontalTextAlignment="Center"
                    TextColor="{StaticResource TextDark}"/>
            </Border>

            <!-- Quick Save/Load Section -->
            <Label 
                Text="Quick Save/Load" 
                FontSize="18" 
                FontAttributes="Bold"
                TextColor="{StaticResource TextDark}"
                Margin="20,10,20,5"/>
            
            <Label 
                Text="Save and load from default app location"
                FontSize="12"
                Opacity="0.7"
                Margin="20,0"/>

            <Grid ColumnDefinitions="*,*" ColumnSpacing="10" Margin="20,0">
                <Button
                    Grid.Column="0"
                    BackgroundColor="{StaticResource PrimaryDark}"
                    Command="{Binding SaveCommand}"
                    CornerRadius="15"
                    FontAttributes="Bold"
                    HeightRequest="50"
                    Text="💾 Save"
                    TextColor="{StaticResource CardBackground}" />

                <Button
                    Grid.Column="1"
                    BackgroundColor="{StaticResource PrimaryLight}"
                    Command="{Binding LoadCommand}"
                    CornerRadius="15"
                    FontAttributes="Bold"
                    HeightRequest="50"
                    Text="📂 Load"
                    TextColor="{StaticResource CardBackground}" />
            </Grid>

            <!-- Custom File Section -->
            <Label 
                Text="Custom File Location" 
                FontSize="18" 
                FontAttributes="Bold"
                TextColor="{StaticResource TextDark}"
                Margin="20,20,20,5"/>
            
            <Label 
                Text="Import from or export to a specific file"
                FontSize="12"
                Opacity="0.7"
                Margin="20,0"/>

            <Grid ColumnDefinitions="*,*" ColumnSpacing="10" Margin="20,0">
                <Button
                    Grid.Column="0"
                    BackgroundColor="{StaticResource PrimaryDark}"
                    Command="{Binding SaveToFileCommand}"
                    CornerRadius="15"
                    FontAttributes="Bold"
                    HeightRequest="50"
                    Text="📤 Export..."
                    TextColor="{StaticResource CardBackground}" />

                <Button
                    Grid.Column="1"
                    BackgroundColor="{StaticResource PrimaryLight}"
                    Command="{Binding LoadFromFileCommand}"
                    CornerRadius="15"
                    FontAttributes="Bold"
                    HeightRequest="50"
                    Text="📥 Import..."
                    TextColor="{StaticResource CardBackground}" />
            </Grid>

            <!-- PDF Export Section -->
            <Label 
                Text="Reports" 
                FontSize="18" 
                FontAttributes="Bold"
                TextColor="{StaticResource TextDark}"
                Margin="20,20,20,5"/>
            
            <Label 
                Text="Generate a printable task report"
                FontSize="12"
                Opacity="0.7"
                Margin="20,0"/>

            <Button
                Margin="20,0"
                BackgroundColor="{StaticResource PrimaryDark}"
                Command="{Binding GeneratePdfCommand}"
                CornerRadius="15"
                FontAttributes="Bold"
                HeightRequest="50"
                Text="📄 Export to PDF"
                TextColor="{StaticResource CardBackground}" />

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>