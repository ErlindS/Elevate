<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:Elevate"
    xmlns:views="clr-namespace:Elevate.Views"
    x:Class="Elevate.AppShell"
    Title="Elevate"
    BackgroundColor="{StaticResource CardBackground}"
    FlyoutBackgroundColor="{StaticResource CardBackground}"
    TitleColor="{StaticResource PrimaryDark}"
    FlyoutBehavior="Locked">

    <!-- Flyout-Items: grüner Text auf weißem Hintergrund -->
    <Shell.ItemTemplate>
        <DataTemplate>
            <Grid ColumnDefinitions="Auto, *" Padding="15,10" ColumnSpacing="12">
                <Image Source="{Binding FlyoutIcon}"
                       HeightRequest="20"
                       WidthRequest="20"
                       VerticalOptions="Center" />
                <Label Grid.Column="1"
                       Text="{Binding Title}"
                       FontSize="15"
                       TextColor="{StaticResource PrimaryDark}"
                       VerticalOptions="Center" />
            </Grid>
        </DataTemplate>
    </Shell.ItemTemplate>
    <!-- Alle Views MÜSSEN hier registriert sein -->
    <ShellContent
        Title="Todays Task"
        ContentTemplate="{DataTemplate local:TodaysTaskPage}"
        Route="TodaysTaskPage" />


    <ShellContent
        Title="Add Task"
        ContentTemplate="{DataTemplate local:AddTaskPage}"
        Route="AddTaskPage" />

    <ShellContent
        Title="Combine Tasks"
        ContentTemplate="{DataTemplate local:CombineTaskPage}"
        Route="CombineTaskPage" />

    <!-- <ShellContent
        Title="Dashboard"
        ContentTemplate="{DataTemplate local:DashboardPage}"
        Route="DashboardPage" /> -->

    <ShellContent
        Title="Weekly Calendar"
        ContentTemplate="{DataTemplate views:WeeklyCalendarPage}"
        Route="WeeklyCalendarPage" />

    <ShellContent
        Title="Export"
        ContentTemplate="{DataTemplate local:ExportPage}"
        Route="ExportPage" />

    <!-- <ShellContent 
        Title="Häuser"
        ContentTemplate="{DataTemplate views:CompletedHousesPage}"
        Route="completedhouses" /> -->

    <!-- Theme Toggle im Flyout Footer -->
    <Shell.FlyoutFooterTemplate>
        <DataTemplate>
            <Grid Padding="15,10" BackgroundColor="Transparent">
                <Button x:Name="ThemeToggleBtn"
                        Text="🌙 Dark Mode"
                        BackgroundColor="{StaticResource PrimaryDark}"
                        TextColor="{StaticResource CardBackground}"
                        CornerRadius="12"
                        FontAttributes="Bold"
                        FontSize="13"
                        HeightRequest="40"
                        Clicked="OnThemeToggleClicked" />
            </Grid>
        </DataTemplate>
    </Shell.FlyoutFooterTemplate>

</Shell>
