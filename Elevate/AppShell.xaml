<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:Elevate"
    xmlns:views="clr-namespace:Elevate.Views"
    x:Class="Elevate.AppShell"
    Title="Elevate"
    BackgroundColor="{StaticResource CardBackground}"
    FlyoutBackgroundColor="{StaticResource CardBackground}"
    TitleColor="{StaticResource PrimaryDark}"
    FlyoutBehavior="Locked">

    <!-- Flyout-Items: grüner Text auf weißem Hintergrund -->
    <Shell.ItemTemplate>
        <DataTemplate>
            <Grid ColumnDefinitions="4, Auto, *" Padding="0,8,15,8" ColumnSpacing="10"
                  BackgroundColor="Transparent">
                <!-- Grüner Indikator-Balken -->
                <BoxView x:Name="Indicator"
                         Grid.Column="0"
                         BackgroundColor="{StaticResource PrimaryDark}"
                         CornerRadius="2"
                         WidthRequest="4"
                         VerticalOptions="Fill" />
                <Image Grid.Column="1"
                       Source="{Binding FlyoutIcon}"
                       HeightRequest="20"
                       WidthRequest="20"
                       VerticalOptions="Center"
                       Margin="8,0,0,0" />
                <Label Grid.Column="2"
                       Text="{Binding Title}"
                       FontSize="15"
                       FontAttributes="Bold"
                       TextColor="{StaticResource PrimaryDark}"
                       VerticalOptions="Center" />

                <VisualStateManager.VisualStateGroups>
                    <VisualStateGroupList>
                        <VisualStateGroup x:Name="CommonStates">
                            <VisualState x:Name="Normal">
                                <VisualState.Setters>
                                    <Setter TargetName="Indicator" Property="BoxView.IsVisible" Value="False" />
                                    <Setter TargetName="Indicator" Property="BoxView.BackgroundColor" Value="Transparent" />
                                </VisualState.Setters>
                            </VisualState>
                            <VisualState x:Name="Selected">
                                <VisualState.Setters>
                                    <Setter TargetName="Indicator" Property="BoxView.IsVisible" Value="True" />
                                    <Setter TargetName="Indicator" Property="BoxView.BackgroundColor" Value="{StaticResource PrimaryDark}" />
                                    <Setter Property="BackgroundColor" Value="{StaticResource PageBackground}" />
                                </VisualState.Setters>
                            </VisualState>
                        </VisualStateGroup>
                    </VisualStateGroupList>
                </VisualStateManager.VisualStateGroups>
            </Grid>
        </DataTemplate>
    </Shell.ItemTemplate>
    <!-- Alle Views MÜSSEN hier registriert sein -->
    <ShellContent
        Title="Todays Task"
        ContentTemplate="{DataTemplate local:TodaysTaskPage}"
        Route="TodaysTaskPage" />


    <ShellContent
        Title="Add Task"
        ContentTemplate="{DataTemplate local:AddTaskPage}"
        Route="AddTaskPage" />

    <ShellContent
        Title="Combine Tasks"
        ContentTemplate="{DataTemplate local:CombineTaskPage}"
        Route="CombineTaskPage" />

    <!-- <ShellContent
        Title="Dashboard"
        ContentTemplate="{DataTemplate local:DashboardPage}"
        Route="DashboardPage" /> -->

    <ShellContent
        Title="Weekly Calendar"
        ContentTemplate="{DataTemplate views:WeeklyCalendarPage}"
        Route="WeeklyCalendarPage" />

    <ShellContent
        Title="Export"
        ContentTemplate="{DataTemplate local:ExportPage}"
        Route="ExportPage" />

    <!-- <ShellContent 
        Title="Häuser"
        ContentTemplate="{DataTemplate views:CompletedHousesPage}"
        Route="completedhouses" /> -->

    <!-- Theme Toggle im Flyout Footer -->
    <Shell.FlyoutFooterTemplate>
        <DataTemplate>
            <Grid Padding="15,10" BackgroundColor="Transparent">
                <Button x:Name="ThemeToggleBtn"
                        Text="🌙 Dark Mode"
                        BackgroundColor="{StaticResource PrimaryDark}"
                        TextColor="{StaticResource CardBackground}"
                        CornerRadius="12"
                        FontAttributes="Bold"
                        FontSize="13"
                        HeightRequest="40"
                        Clicked="OnThemeToggleClicked" />
            </Grid>
        </DataTemplate>
    </Shell.FlyoutFooterTemplate>

</Shell>
