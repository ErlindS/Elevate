<?xml version="1.0" encoding="UTF-8" ?>
<?xaml-comp compile="true" ?>
<ResourceDictionary 
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- ======================================== -->
    <!-- LIGHT MODE: Sage-to-Teal Green           -->
    <!-- ======================================== -->

    <Color x:Key="GradientStart">#3B7A57</Color>
    <Color x:Key="GradientEnd">#5BA882</Color>
    <Color x:Key="PrimaryDark">#3B7A57</Color>
    <Color x:Key="PrimaryLight">#5BA882</Color>
    <Color x:Key="PageBackground">#F5F7F5</Color>
    <Color x:Key="CardBackground">#FFFFFF</Color>
    <Color x:Key="StatusBackground">#E8F5E9</Color>
    <Color x:Key="HouseBackground">#D2DCB6</Color>
    <Color x:Key="FlyoutBackground">#3B7A57</Color>
    <Color x:Key="TextDark">#4A4A4A</Color>
    <Color x:Key="HouseText">#333333</Color>
    <Color x:Key="TextMuted">#999999</Color>
    <Color x:Key="TextPlaceholder">#CCCCCC</Color>
    <Color x:Key="Success">#66BB6A</Color>
    <Color x:Key="Warning">#FFA726</Color>
    <Color x:Key="Error">#E57373</Color>
    <Color x:Key="Divider">#EEEEEE</Color>
    <Color x:Key="CalendarGray">#F0F0F0</Color>
    <Color x:Key="GridLine">#E0E0E0</Color>

    <!-- ======================================== -->
    <!-- DARK MODE: Tokyo Night                    -->
    <!-- ======================================== -->

    <Color x:Key="DarkGradientStart">#24283b</Color>
    <Color x:Key="DarkGradientEnd">#bb9af7</Color>
    <Color x:Key="DarkPrimaryDark">#bb9af7</Color>
    <Color x:Key="DarkPrimaryLight">#7aa2f7</Color>
    <Color x:Key="DarkPageBackground">#1a1b26</Color>
    <Color x:Key="DarkCardBackground">#24283b</Color>
    <Color x:Key="DarkStatusBackground">#1f2335</Color>
    <Color x:Key="DarkHouseBackground">#1f2335</Color>
    <Color x:Key="DarkFlyoutBackground">#1a1b26</Color>
    <Color x:Key="DarkTextDark">#c0caf5</Color>
    <Color x:Key="DarkHouseText">#c0caf5</Color>
    <Color x:Key="DarkTextMuted">#565f89</Color>
    <Color x:Key="DarkTextPlaceholder">#414868</Color>
    <Color x:Key="DarkSuccess">#9ece6a</Color>
    <Color x:Key="DarkWarning">#ff9e64</Color>
    <Color x:Key="DarkError">#f7768e</Color>
    <Color x:Key="DarkDivider">#3b4261</Color>
    <Color x:Key="DarkCalendarGray">#1f2335</Color>
    <Color x:Key="DarkGridLine">#3b4261</Color>

    <!-- ======================================== -->
    <!-- Basis & Graustufen                        -->
    <!-- ======================================== -->

    <Color x:Key="White">White</Color>
    <Color x:Key="Black">Black</Color>
    <Color x:Key="OffBlack">#1f1f1f</Color>
    <Color x:Key="Gray100">#E1E1E1</Color>
    <Color x:Key="Gray200">#C8C8C8</Color>
    <Color x:Key="Gray300">#ACACAC</Color>
    <Color x:Key="Gray400">#919191</Color>
    <Color x:Key="Gray500">#6E6E6E</Color>
    <Color x:Key="Gray600">#404040</Color>
    <Color x:Key="Gray900">#212121</Color>
    <Color x:Key="Gray950">#141414</Color>

    <!-- ======================================== -->
    <!-- Brushes                                   -->
    <!-- ======================================== -->

    <SolidColorBrush x:Key="PrimaryDarkBrush" Color="{StaticResource PrimaryDark}"/>
    <SolidColorBrush x:Key="PrimaryLightBrush" Color="{StaticResource PrimaryLight}"/>
    <SolidColorBrush x:Key="WhiteBrush" Color="{StaticResource White}"/>
    <SolidColorBrush x:Key="BlackBrush" Color="{StaticResource Black}"/>

    <SolidColorBrush x:Key="Gray100Brush" Color="{StaticResource Gray100}"/>
    <SolidColorBrush x:Key="Gray200Brush" Color="{StaticResource Gray200}"/>
    <SolidColorBrush x:Key="Gray300Brush" Color="{StaticResource Gray300}"/>
    <SolidColorBrush x:Key="Gray400Brush" Color="{StaticResource Gray400}"/>
    <SolidColorBrush x:Key="Gray500Brush" Color="{StaticResource Gray500}"/>
    <SolidColorBrush x:Key="Gray600Brush" Color="{StaticResource Gray600}"/>
    <SolidColorBrush x:Key="Gray900Brush" Color="{StaticResource Gray900}"/>
    <SolidColorBrush x:Key="Gray950Brush" Color="{StaticResource Gray950}"/>

    <!-- Gradient Brushes -->
    <LinearGradientBrush x:Key="AppGradientBrush" StartPoint="0,0.5" EndPoint="1,0.5">
        <GradientStop Color="{StaticResource GradientStart}" Offset="0.0" />
        <GradientStop Color="{StaticResource GradientEnd}" Offset="1.0" />
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="DarkGradientBrush" StartPoint="0,0.5" EndPoint="1,0.5">
        <GradientStop Color="{StaticResource DarkGradientStart}" Offset="0.0" />
        <GradientStop Color="{StaticResource DarkGradientEnd}" Offset="1.0" />
    </LinearGradientBrush>

</ResourceDictionary>